---
const whatsappNumber = "+59895546950";
const whatsappText = encodeURIComponent("Hola, quiero hacer una consulta sobre las mantas.");
---

<section id="contacto" class="px-6 py-20 sm:px-10 lg:px-12">
  <div class="mx-auto max-w-5xl rounded-[2rem] bg-bark px-8 py-12 text-oat shadow-soft sm:px-12">
    <p class="text-sm font-semibold uppercase tracking-[0.28em] text-sand">Contacto</p>
    <h2 class="mt-4 font-display text-4xl font-semibold sm:text-5xl">Hablemos directo y sin vueltas.</h2>
    <p class="mt-5 max-w-2xl text-lg leading-8 text-oat/80">
      Si querés consultar por un color, tamaño o envío, escribinos por WhatsApp y resolveremos tu duda a la brevedad.
    </p>

    <div class="mt-10">
      <a
        href={`https://api.whatsapp.com/send?phone=${whatsappNumber}&text=${whatsappText}`}
        target="_blank"
        rel="noreferrer"
        class="block rounded-[1.5rem] bg-oat px-6 py-6 text-bark transition hover:bg-white"
      >
        <p class="text-xs font-semibold uppercase tracking-[0.22em] text-ember">WhatsApp</p>
        <p class="mt-3 font-display text-3xl">Escribinos ahora</p>
        <p class="mt-2 text-base leading-7 text-bark/75">Atención directa para consultas, pedidos y coordinación de envíos.</p>
      </a>
    </div>
  </div>
</section>