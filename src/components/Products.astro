---
import { Image } from "astro:assets";
import natural from "../assets/products/manta-natural.svg";
import terracota from "../assets/products/manta-terracota.svg";
import musgo from "../assets/products/manta-musgo.svg";

const whatsappNumber = "+59895546950";

const products = [
  {
    name: "Manta Natural",
    color: "Tono crudo suave",
    detail: "Ideal para un living cálido o para sumar textura al dormitorio.",
    image: natural
  },
  {
    name: "Manta Terracota",
    color: "Terracota cálido",
    detail: "Una variante con más presencia visual, perfecta para rincones de lectura.",
    image: terracota
  },
  {
    name: "Manta Musgo",
    color: "Verde musgo",
    detail: "Una opción sobria y natural para espacios tranquilos y neutros.",
    image: musgo
  }
];
---

<section id="productos" class="px-6 py-20 sm:px-10 lg:px-12">
  <div class="mx-auto max-w-6xl">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.28em] text-ember">Productos</p>
        <h2 class="mt-3 font-display text-4xl font-semibold text-bark sm:text-5xl">Tres mantas, un mismo oficio, distintos colores.</h2>
      </div>
      <p class="max-w-xl text-base leading-7 text-bark/75">
        Trabajamos con pocas variantes para concentrarnos en la calidad del tejido y la terminación.
      </p>
    </div>

    <div class="mt-12 grid gap-8 lg:grid-cols-3">
      {products.map((product) => {
        const text = encodeURIComponent(`Hola, quiero consultar por la ${product.name}.`);
        return (
          <article class="overflow-hidden rounded-[2rem] border border-bark/10 bg-white shadow-soft">
            <Image src={product.image} alt={product.name} class="h-72 w-full object-cover" />
            <div class="p-6">
              <p class="text-xs font-semibold uppercase tracking-[0.22em] text-ember">{product.color}</p>
              <h3 class="mt-3 font-display text-3xl text-bark">{product.name}</h3>
              <p class="mt-4 text-base leading-7 text-bark/75">{product.detail}</p>
              <a
                href={`https://api.whatsapp.com/send?phone=${whatsappNumber}&text=${text}`}
                target="_blank"
                rel="noreferrer"
                class="mt-6 inline-flex items-center rounded-full bg-bark px-6 py-3 text-sm font-semibold uppercase tracking-[0.18em] text-oat transition hover:bg-[#46301f]"
              >
                Consultar por WhatsApp
              </a>
            </div>
          </article>
        );
      })}
    </div>
  </div>
</section>